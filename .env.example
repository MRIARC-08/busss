# =======================================================
#  Smart Bus Navigator — Environment Variables
#  Copy this file to .env for local dev.
#  For Vercel: add each variable in the Vercel dashboard
#  under Project → Settings → Environment Variables
# =======================================================

# --- Database (PostgreSQL) ---
# For Vercel: use Neon (free tier) or Supabase
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/busdb?sslmode=require"

# --- Delhi GTFS Realtime API ---
# Get your key from: https://otd.delhi.gov.in/
DELHI_GTFS_API_KEY="your_delhi_gtfs_api_key_here"

# --- JWT Secret ---
# Generate a strong random string: openssl rand -hex 32
JWT_SECRET="your_strong_random_jwt_secret_here"

# --- OpenRouteService API (client-side, prefix with NEXT_PUBLIC_) ---
# Get free key at: https://openrouteservice.org/dev/#/signup
NEXT_PUBLIC_ORS_API_KEY="your_ors_api_key_here"
